rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowed() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email));
    }

    function isAdmin() {
      return isAllowed()
        && get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.role == "Admin";
    }

    match /allowedUsers/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
      allow write: if false;
    }

    match /categories/{categoryId} {
      allow read: if isAllowed();
      allow create: if isAdmin();
      allow update: if isAdmin()
        && (
          !resource.data.system
          || (
            request.resource.data.name   == resource.data.name
            && request.resource.data.type   == resource.data.type
            && request.resource.data.active == resource.data.active
          )
        );
      allow delete: if false;
    }

    match /transactions/{recordId} {
      allow read: if isAllowed();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

  }
}